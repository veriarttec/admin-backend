#####################################
# VeriART Admin Backend environment #
#####################################

# --- Required (app will fail to start if missing) ---
# Supabase (same project as the main app). NEVER put real values in this file.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Database (Supabase Postgres pooler)
DATABASE_URL=postgresql://postgres.your-project:your-password@your-host:5432/postgres

# JWT - must match the main backend so tokens stay compatible
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret

# Seed script password (used by seed_admins.py; rotate after first login)
ADMIN_SEED_PASSWORD=set-a-strong-password

# --- Optional (defaults exist in config.py) ---
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_NAME=ArtPriv Admin Portal
DEBUG=false

# CORS: comma-separated allowed origins (set to the admin frontend custom domain in prod)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Set to "production" on deployed environments (disables all dev-only behavior)
ENVIRONMENT=production

# File Upload (10MB default)
MAX_FILE_SIZE=10485760

# Supabase Storage Buckets
BUCKET_CERTIFICATIONS=certification-documents
BUCKET_CONSENT_FORMS=consent-forms
BUCKET_TEST_REPORTS=test-reports
BUCKET_COUNSELING_REPORTS=counseling-reports
